# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env (já está no .gitignore)

# ─── Anthropic ───────────────────────────────────────────────
# Como obter: https://console.anthropic.com/settings/keys → Create Key
ANTHROPIC_API_KEY=sk-ant-...

# Código de acesso da equipe — distribua via Slack para os usuários
# Deixe em branco para desabilitar a validação (não recomendado em produção)
ACCESS_CODE=guidely-ccap-2026

# ─── Anthropic OAuth (gera API key automaticamente) ──────────
# Como obter client_id:
# 1. Acesse https://console.anthropic.com/settings/oauth-apps
# 2. Clique em "Create OAuth App"
# 3. Redirect URI: https://SEU-DOMINIO.vercel.app/api/auth/anthropic/callback
# 4. Escopos necessários: org:create_api_key user:profile
# Nota: client_secret é opcional se usar PKCE puro
ANTHROPIC_CLIENT_ID=
ANTHROPIC_CLIENT_SECRET=
ANTHROPIC_REDIRECT_URI=https://SEU-DOMINIO.vercel.app/api/auth/anthropic/callback

# ─── Figma OAuth ─────────────────────────────────────────────
# Como obter:
# 1. Acesse https://www.figma.com/developers/apps
# 2. Clique em "Create a new app"
# 3. Copie o Client ID e Client Secret
# 4. Adicione a Redirect URI: https://SEU-DOMINIO.vercel.app/api/auth/callback
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_REDIRECT_URI=https://SEU-DOMINIO.vercel.app/api/auth/callback

# ─── Upstash Redis (storage temporário para OAuth) ───────────
# Como obter: https://console.upstash.com → Create Database
# Tier gratuito é suficiente (10k comandos/dia)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=
